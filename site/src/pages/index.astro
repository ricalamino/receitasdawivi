---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ReceitaCard from '../components/ReceitaCard.astro';
import BuscaReceitas from '../components/BuscaReceitas.astro';

const receitas = await getCollection('receitas');
receitas.sort((a, b) => a.data.title.localeCompare(b.data.title, 'pt-BR'));
---

<Base title="Início">
  <h1 class="text-3xl font-bold text-violet-700 mb-2">Todas as Receitas</h1>
  <p class="text-gray-500 mb-6">{receitas.length} receitas no total</p>

  <BuscaReceitas />

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {receitas.map((r) => (
      <ReceitaCard
        title={r.data.title}
        categoria={r.data.categoria}
        slug={r.id}
        tags={r.data.tags}
      />
    ))}
  </div>
</Base>
