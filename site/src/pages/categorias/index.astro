---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const receitas = await getCollection('receitas');

const categorias = [
  { id: 'low-carb', label: '🥗 Low Carb' },
  { id: 'bolos', label: '🍰 Bolos' },
  { id: 'tortas', label: '🥧 Tortas' },
  { id: 'mousses', label: '🍮 Mousses' },
  { id: 'muffins', label: '🧁 Muffins' },
];

const contagem = Object.fromEntries(
  categorias.map((c) => [c.id, receitas.filter((r) => r.data.categoria === c.id).length])
);
---

<Base title="Categorias">
  <h1 class="text-3xl font-bold text-violet-700 mb-8">Categorias</h1>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {categorias.map((c) => (
      <a
        href={`/categorias/${c.id}`}
        class="flex items-center justify-between bg-white rounded-xl p-5 shadow-sm border border-violet-100 hover:border-violet-300 hover:shadow-md transition-all"
      >
        <span class="text-lg font-semibold">{c.label}</span>
        <span class="text-sm text-violet-600 font-medium">{contagem[c.id]} receitas</span>
      </a>
    ))}
  </div>
</Base>
