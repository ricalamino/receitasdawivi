---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ReceitaCard from '../../components/ReceitaCard.astro';

const categorias = ['low-carb', 'bolos', 'tortas', 'mousses', 'muffins'] as const;
type Categoria = typeof categorias[number];

export async function getStaticPaths() {
  const receitas = await getCollection('receitas');
  return ['low-carb', 'bolos', 'tortas', 'mousses', 'muffins'].map((cat) => ({
    params: { categoria: cat },
    props: { receitas: receitas.filter((r) => r.data.categoria === cat) },
  }));
}

const { categoria } = Astro.params;
const { receitas } = Astro.props;
receitas.sort((a, b) => a.data.title.localeCompare(b.data.title, 'pt-BR'));

const categoriaLabel: Record<string, string> = {
  'low-carb': '🥗 Low Carb',
  'bolos': '🍰 Bolos',
  'tortas': '🥧 Tortas',
  'mousses': '🍮 Mousses',
  'muffins': '🧁 Muffins',
};
---

<Base title={categoriaLabel[categoria] ?? categoria}>
  <div class="mb-4">
    <a href="/categorias" class="text-violet-600 text-sm hover:underline">← Categorias</a>
  </div>

  <h1 class="text-3xl font-bold text-violet-700 mb-2">{categoriaLabel[categoria]}</h1>
  <p class="text-gray-500 mb-8">{receitas.length} receitas</p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {receitas.map((r) => (
      <ReceitaCard
        title={r.data.title}
        categoria={r.data.categoria}
        slug={r.id}
        tags={r.data.tags}
      />
    ))}
  </div>
</Base>
