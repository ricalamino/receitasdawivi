---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ReceitaCard from '../../components/ReceitaCard.astro';

export async function getStaticPaths() {
  const receitas = await getCollection('receitas');
  const tags = [...new Set(receitas.flatMap((r) => r.data.tags ?? []))];
  return tags.map((tag) => ({
    params: { tag },
    props: { receitas: receitas.filter((r) => r.data.tags?.includes(tag)) },
  }));
}

const { tag } = Astro.params;
const { receitas } = Astro.props;
receitas.sort((a, b) => a.data.title.localeCompare(b.data.title, 'pt-BR'));
---

<Base title={tag}>
  <div class="mb-4">
    <a href="/" class="text-violet-600 text-sm hover:underline">← Todas as receitas</a>
  </div>

  <h1 class="text-3xl font-bold text-violet-700 mb-2">#{tag}</h1>
  <p class="text-gray-500 mb-8">{receitas.length} receitas</p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {receitas.map((r) => (
      <ReceitaCard
        title={r.data.title}
        categoria={r.data.categoria}
        slug={r.id}
        tags={r.data.tags}
      />
    ))}
  </div>
</Base>
